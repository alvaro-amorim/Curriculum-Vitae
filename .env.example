# Local app URL used by future integrations and deploy checks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase is future/optional and is not required for the current local/mock API mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret for future Supabase admin operations.
# Never expose this value in client components or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# The current API routes work in local/mock mode without Supabase variables.
