# Public app URL used by local checks, metadata and deployment wiring.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL used by server-side Arcade APIs.
# Keep this file sanitized; the real value belongs in .env.local/Vercel env.
NEXT_PUBLIC_SUPABASE_URL=

# Server-only key used by Route Handlers to read/write Arcade tables.
# Never expose this value in client components or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only HMAC secret used to hash anonymous Arcade session cookies.
# Generate a long random value in each environment. Never expose it in NEXT_PUBLIC_*.
ARCADE_SESSION_SECRET=
