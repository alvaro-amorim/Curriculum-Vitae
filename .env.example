# Public app URL used by local checks, metadata and deployment wiring.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas connection used only by server-side code.
# Include the logical database in the URI and use the restricted portfolio_app user.
MONGODB_URI=
MONGODB_DB=portfolio_os

# Supabase remains active temporarily for Arcade data and Admin authentication
# while the MongoDB migration is implemented and validated.
NEXT_PUBLIC_SUPABASE_URL=

# Server-only anonymous key used exclusively by the Admin Auth server client.
# Do not expose this variable through NEXT_PUBLIC_*.
SUPABASE_ANON_KEY=

# Server-only key used by Route Handlers to read/write current Arcade tables and Admin metrics.
# Never expose this value in client components or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only HMAC secret used to hash anonymous Arcade session cookies.
# Generate a long random value in each environment. Never expose it in NEXT_PUBLIC_*.
ARCADE_SESSION_SECRET=

# Exact e-mail allowed to access /admin. Create this user manually in Supabase Auth.
ADMIN_EMAIL=
