# Public app URL used by local checks, metadata and deployment wiring.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas connection used only by server-side code.
# Include the logical database in the URI and use a restricted application user.
MONGODB_URI=
MONGODB_DB=portfolio_os

# Server-only HMAC secret used to hash anonymous Arcade session cookies.
# Generate a long random value in each environment. Never expose it in NEXT_PUBLIC_*.
ARCADE_SESSION_SECRET=

# Server-only Cloudinary credentials used by Admin project media uploads.
# Never expose these values in NEXT_PUBLIC_* variables.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
